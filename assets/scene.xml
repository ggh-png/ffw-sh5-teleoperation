<?xml version="1.0" encoding="utf-8"?>
<!-- FFW-SH5 simulation scene — Y-up physics coordinates.
     Kept outside the robotis_mujoco_menagerie submodule so it can be
     version-controlled in the main repo.

     box size="half_x half_y half_z"    (MJCF convention)
     cylinder size="radius half_height" (MJCF convention)
     mass=0 → static;  mass>0 → dynamic rigid body              -->
<scene>

  <!-- ── Table ──────────────────────────────────────────────────────────── -->
  <body name="table" pos="0 0.325 -0.65">
    <geom type="box"
          size="0.30 0.325 0.25"
          mass="1000"
          friction="0.8"
          rgba="0.55 0.35 0.15 1"/>
  </body>

  <!-- ── Soda can: center_y = table_top(0.65) + halfH(0.075) + gap(0.001) ── -->
  <body name="can_0" pos="0 0.726 -0.65">
    <geom type="mesh"
          file="soda_can_stl/soda_can.stl"
          scale="1.0"
          mass="0.5"
          friction="0.7"
          rgba="0.85 0.08 0.08 1"/>
  </body>

</scene>
